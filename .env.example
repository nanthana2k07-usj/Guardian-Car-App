# OTP Configuration
# Mode can be: console, smtp, or resend
OTP_EMAIL_MODE=console
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_MS=30000

# Option 1: Gmail / Custom SMTP Settings (Used when OTP_EMAIL_MODE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM="GuardianCar <your-email@gmail.com>"

# Option 2: Resend API Settings (Used when OTP_EMAIL_MODE=resend)
RESEND_API_KEY=re_123456789
RESEND_FROM="GuardianCar <onboarding@resend.dev>"

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/guardian-car
